# SignalDelta portal proxy — environment template.
# Copy this file to .env and fill in real values. Never commit .env to git.

# REQUIRED — 32-character random bearer token. Replace the placeholder below
# with the actual random value generated for your install. The same value must
# also be set as VITE_PROXY_API_TOKEN in the portal repo's GitHub Secrets.
# Regenerate with:   python -c "import secrets; print(secrets.token_urlsafe(24))"
PROXY_API_TOKEN=REPLACE_WITH_32_CHAR_URLSAFE_BASE64_TOKEN

# Local Neo4j connection — these are the defaults for the local engine
# install per v3 §15 (bolt://localhost:7687).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_WITH_YOUR_NEO4J_PASSWORD

# Alpha Vantage API key for the GET /macro_news endpoint (Portal v1.1 Change 4).
# Share the same key the engine uses for its per-asset news scan — combined
# daily budget on the free tier is 25 calls, so don't duplicate the key onto
# a separate account. The endpoint caches 60 minutes so it consumes ≤ 24
# calls/day on its own.
# When the key is missing, /macro_news returns HTTP 503 with a clear JSON
# error body; the rest of the proxy continues serving Neo4j queries normally.
ALPHA_VANTAGE_API_KEY=REPLACE_WITH_YOUR_ALPHA_VANTAGE_KEY

# Alpaca paper credentials for the GET /market_calendar endpoint (market-
# status clock dispatch 2026-05-26). Same credentials the engine uses for
# Phase 1 paper execution — share the values. The calendar endpoint is
# identical on paper and live, so paper-api is sufficient.
# Note: the env var is ALPACA_API_SECRET (not ALPACA_SECRET_KEY) — the
# May-2026 Alpaca 401-unauthorized incident traced to that naming mismatch.
# Accept ALPACA_API_KEY or APCA_API_KEY_ID for the key, and
# ALPACA_API_SECRET / ALPACA_SECRET_KEY / APCA_API_SECRET_KEY for the secret.
# When either is missing, /market_calendar returns {calendar: null,
# fallback: true} and the portal falls back to weekday-only logic.
ALPACA_API_KEY=REPLACE_WITH_YOUR_ALPACA_PAPER_KEY
ALPACA_API_SECRET=REPLACE_WITH_YOUR_ALPACA_PAPER_SECRET

# ─── Phase 3d-iii-a: search-master (7688) operator surface ───────────────────
# The SEPARATE search-master Neo4j instance (Community) — provisioned by the
# operator via infra/provision_neo4j_7688.ps1. Distinct instance/port from the
# 7687 trading engine (§6 isolation). The proxy's /sm/* route group binds ONLY
# this connection; leave SM_NEO4J_PASSWORD blank until 7688 is provisioned (the
# /sm/* endpoints return 503 until then — the auth + allowlist gates still run).
SM_NEO4J_URI=bolt://localhost:7688
SM_NEO4J_USER=neo4j
SM_NEO4J_PASSWORD=REPLACE_AFTER_PROVISIONING_7688
SM_NEO4J_DATABASE=neo4j
# Optional on-disk backing dir for the server-side secrets store (onboarding
# data-source credentials). In-memory if unset. Values are NEVER logged/returned.
SM_SECRETS_DIR=

# Cloudflare API token slot — used ONLY by infra/apply_access_and_tunnel.ps1 to
# apply the Cloudflare Access policy (auth off the client). PASTE the token here
# at apply time; it is never read by the proxy process itself.
CLOUDFLARE_API_TOKEN=REPLACE_AT_APPLY_TIME_THEN_CLEAR

# --- market-data feed (search-master revival scan + V-015 probe) --------------
# Alpaca is already set above (ALPACA_API_KEY / ALPACA_API_SECRET) — READ ONLY here.
# NASDAQ_DATA_LINK_API_KEY currently lives as a Windows USER env var (works for
# interactive runs). MIRROR it here so a service under another account inherits it.
# Operator pastes the value; it never enters Code's context.
NASDAQ_DATA_LINK_API_KEY=
